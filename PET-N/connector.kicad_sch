	(text "Locking MX switches are hard to get, but if you have one it \ncan be used, or it can be jumpered for SW13 (new) or SW51 (sjg).\nSolder-jumper default is SW13. Cut/re-solder for other options.\n"
		(exclude_from_sim no)
		(at 30.607 47.625 0)
		(effects
			(font
				(size 1.4 1.4)
			)
			(justify left bottom)
		)
		(uuid "3b5164f4-0ee0-4d43-a371-04288b656cdb")
	)
	(text "Solder JP1 and JP2 if original \n20 pin connector is used (i.e\nnone of the controllers)"
		(exclude_from_sim no)
		(at 130.048 109.855 0)
		(effects
			(font
				(size 1.4 1.4)
			)
			(justify left bottom)
		)
		(uuid "472d6e71-bee6-47f1-bb4f-a5d242b26482")
	)
	(text "This switch is not on the keyboard but is assigned\nPETSCII $0A in the matrix. We put it beside the SPACEBAR.\nWe can change the function in firmware. Alternatively, you\ncan assign it to the space key as well. Solder-jumper\ndefault is $0A. Cut/re-solder to map to SPACEBAR\n"
		(exclude_from_sim no)
		(at 30.861 149.733 0)
		(effects
			(font
				(size 1.4 1.4)
			)
			(justify left bottom)
		)
		(uuid "4ac88fbe-85d8-4786-baa5-10dff532188c")
	)
